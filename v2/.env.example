APP_NAME=TestingPrac AI v2
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8090
JWT_SECRET=change-me-in-production
JWT_EXPIRES_MINUTES=10080
# Optional override. If empty, app uses LOCALAPPDATA/testingprac-ai-v2/app.db on Windows.
DATABASE_URL=

# Primary provider: ollama | openai | anthropic
DEFAULT_PROVIDER=ollama

# Models by mode
FAST_MODEL=local-fast
THINK_MODEL=local-think

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional hosted providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
